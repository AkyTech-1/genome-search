<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service web.config for Python / FastAPI
  Tells IIS (Windows hosting) to forward all requests to the Python WSGI app.
  On Linux App Service this file is ignored; startup.sh is used instead.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified"/>
    </handlers>
    <httpPlatform
      processPath="%SystemDrive%\Python313\python.exe"
      arguments="-m uvicorn main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT%"
      stdoutLogEnabled="true"
      stdoutLogFile=".\logs\python.log"
      startupTimeLimit="60"
      requestTimeout="00:04:00">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%"/>
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
